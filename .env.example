# Neon Postgres — pooled connection string from the Neon dashboard.
# Format: postgresql://user:password@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# FBI Crime Data Explorer (free key, https://api.data.gov/signup/)
FBI_API_KEY=

# ACLED (free research access — https://developer.acleddata.com/)
ACLED_API_KEY=
ACLED_EMAIL=

# Optional UNODC override (the dataportal CSV URL changes over time).
# Leave blank to use the default.
UNODC_HOMICIDE_URL=

# Optional: skip DB writes, print a sample to stdout instead.
DRY_RUN=

# Optional overrides:
# UK_AREAS=51.5074,-0.1278;53.4808,-2.2426
# US_STATES=NY,CA,TX,IL,AZ
# US_YEARS=2022,2023
# EU_COUNTRIES=DE,FR,ES,IT,NL
# EU_YEARS=2022,2023
# AU_YEARS=2022,2023
# CA_YEARS=2022,2023
# MX_CRIMES=HOMICIDIO%20DOLOSO,ROBO%20A%20TRANSEUNTE
# ACLED_COUNTRIES=Mexico,Nigeria,Ukraine
# WORLDBANK_YEARS=2021,2022
