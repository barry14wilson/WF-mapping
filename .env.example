# Supabase — use the service role key for writes from connectors.
# Never expose the service key to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# FBI Crime Data Explorer (free key, https://api.data.gov/signup/)
FBI_API_KEY=

# Optional: skip DB writes, print a sample to stdout instead.
DRY_RUN=

# Optional: comma-separated list to override defaults.
# UK_AREAS=51.5074,-0.1278;53.4808,-2.2426
# US_STATES=NY,CA,TX,IL,AZ
# US_YEARS=2022,2023
