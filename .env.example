# Wiley Fox — environment variable template
# Copy to .env.local (gitignored) and fill in real values. NEVER commit real values.
# See Wiley-Fox-Dev-Handoff-v1.md §15 for where to obtain each key.

# --- Content / social pipeline ---
YOUTUBE_API_KEY=
GITHUB_TOKEN=

# --- Map / product (production) ---
# Booking.com affiliate id (replace the prototype's YOUR_AID_HERE placeholder)
BOOKING_AFFILIATE_ID=
# GetYourGuide partner id (public, but parameterise)
GYG_PARTNER_ID=WXZGXR9

# --- Third-party data APIs ---
NUMBEO_API_KEY=
TRIPADVISOR_API_KEY=
FBI_CDE_API_KEY=
KLAVIYO_API_KEY=

# --- Geocoding (if switching off Nominatim) ---
MAPBOX_TOKEN=
GOOGLE_PLACES_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
